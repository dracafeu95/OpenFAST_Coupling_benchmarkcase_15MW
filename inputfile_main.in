RESTART_TYPE = CART
CART_NX = 80
CART_NY = 32
CART_NZ = 32
CART_X_MIN = -240.0
CART_X_MAX = 960.0
CART_Y_MIN = -240.0
CART_Y_MAX = 240.0
CART_Z_MIN = 0.0
CART_Z_MAX = 480.0
