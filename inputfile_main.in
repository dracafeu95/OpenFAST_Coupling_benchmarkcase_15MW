# boundaries ==============================
BOUNDARY x0 DESCRIPTION = 'Inlet'
BOUNDARY x0 TYPE = INLET
BOUNDARY x0 U = INITIAL_FIELD #0.0 0.0 12.0
BOUNDARY x0 LABEL = 'X'

BOUNDARY x1 DESCRIPTION = 'Outlet'
BOUNDARY x1 TYPE = OUTLET
BOUNDARY x1 LABEL = 'X'

BOUNDARY y0 DESCRIPTION = 'Left wall'
BOUNDARY y0 TYPE = SLIP_WALL
BOUNDARY y0 LABEL = 'Y'

BOUNDARY y1 DESCRIPTION = 'Right wall'
BOUNDARY y1 TYPE = SLIP_WALL
BOUNDARY y1 LABEL = 'Y'

BOUNDARY z0 DESCRIPTION = 'Lower wall'
BOUNDARY z0 TYPE = SLIP_WALL
BOUNDARY z0 LABEL = 'Z'

BOUNDARY z1 DESCRIPTION = 'Top wall'
BOUNDARY z1 TYPE = SLIP_WALL
BOUNDARY z1 LABEL = 'Z'

# Dump ====================================
DUMP_TYPE = HDF
DUMP_NPART = 1
DUMP_PREFIX = 'dump/wind_farm.sol'
DUMP_INITIAL_SOLUTION = TRUE
DUMP_FINAL_SOLUTION = TRUE


