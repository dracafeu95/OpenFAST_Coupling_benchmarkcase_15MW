# Main parameters =========================
# run
SOLVER_NAME = 'wind_farm'
SOLVER_TYPE = INCOMPRESSIBLE
NDIM = 3
MOMENTUM_SOURCE_NUMBER = 1.0
DT = 0.025
WALL_CLOCK_TIME_MAX = 36000
TIME_MAX = 5
DUMP_TIME_PERIOD =0.25
ITER_INFO_PERIOD = 1
PRINT_FLOW_RATES = TRUE
TIMER_DISPLAY_THRESHOLD = 0.000000000000000000000
TIMER_DISPLAY_LEVEL = 5
TIMER_DISPLAY_STATS = TRUE

# schemes
TIME_INT = TFV4A
SPACE_INT = 4TH
IMPLICIT_DIFFUSION = TRUE

# Timers
TIMER_DISPLAY_THRESHOLD = 0.0    # minimum value for timer display
TIMER_DISPLAY_LEVEL = 1          # minimum level for timer display

# debug
DEBUG_LEVEL_MASTER = 3

DEBUG_LEVEL_SLAVE = 1
DEBUG_WAIT = 0

# Grid partitioning
NELEMENTPERGROUP = 1000

# parameters
TURBULENCE_MODEL = DYNAMIC_SMAGORINSKY
KINEMATIC_VISCOSITY = 1.517E-5
POISSON_SOLVER = DPCG
PRESSURE_CONVERGENCE = 1.E-6
DENSITY = 1.0

# sponge layer
SPONGE_LAYER_THICKNESS = 10
SPONGE_LAYER_FACTOR = 30.0

STATS U
STATS VELOCITY_SOURCE
STATS NU_T # Or NU_T with constant density solvers
STATS U_U

SCALAR Q_CRITERION TYPE = POSTPROC
SCALAR Q_CRITERION POSTPROC_TYPE = Q_CRITERION
SCALAR Q_CRITERION UPDATE_ONLY_AT_DUMP = TRUE
SCALAR Q_CRITERION UPDATE_ONLY_AT_POSTPROC_DUMP = TRUE

SCALAR VORTICITY TYPE = POSTPROC
SCALAR VORTICITY POSTPROC_TYPE = VORTICITY
SCALAR VORTICITY SOURCE = U
SCALAR VORTICITY UPDATE_ONLY_AT_DUMP = TRUE
SCALAR VORTICITY UPDATE_ONLY_AT_POSTPROC_DUMP = TRUE

SCALAR U_U TYPE = POSTPROC
SCALAR U_U POSTPROC_TYPE = OUTER_PRODUCT
SCALAR U_U SOURCE1 = U
SCALAR U_U SOURCE2 = U

COND_STATS U TYPE = REYNOLDS #Default
COND_STATS U FREQUENCY = 1 #Default
COND_STATS U NBIN = 10 #Default
COND_STATS U COND_TYPE = PERIODIC
COND_STATS U COND_DATA = TOTAL_TIME #Default
COND_STATS U SOURCE = U
COND_STATS U BIN_SIZE = 5.0
COND_STATS U COND_DATA_MIN = 0.0 #Default 
COND_STATS U COND_DATA_MAX = 0.01563
#COND_STATS U RESET_COND_STATS = TRUE #Default

COND_STATS U_U TYPE = REYNOLDS #Default
COND_STATS U_U FREQUENCY = 1 #Default
COND_STATS U_U NBIN = 10 #Default
COND_STATS U_U COND_TYPE = PERIODIC
COND_STATS U_U COND_DATA = TOTAL_TIME #Default
COND_STATS U_U SOURCE = U_U
COND_STATS U_U BIN_SIZE = 5.0
COND_STATS U_U COND_DATA_MIN = 0.0 #Default 
COND_STATS U_U COND_DATA_MAX = 0.01563
#COND_STATS U_U RESET_COND_STATS = TRUE #Default

SCALAR ANISOTROPIC_T TYPE = POSTPROC
SCALAR ANISOTROPIC_T POSTPROC_TYPE = ANISOTROPIC_TENSOR
SCALAR ANISOTROPIC_T CONDITIONAL_STATS_BIN = 0 # Default value, if using conditional stats it allows to select the requested bin
SCALAR ANISOTROPIC_T UPDATE_ONLY_AT_DUMP = TRUE
SCALAR ANISOTROPIC_T UPDATE_ONLY_AT_POSTPROC_DUMP = TRUE

SCALAR ANISOTROPIC_T TYPE = POSTPROC
SCALAR ANISOTROPIC_T POSTPROC_TYPE = ANISOTROPIC_TENSOR

SCALAR ANI_BM TYPE = POSTPROC
SCALAR ANI_BM POSTPROC_TYPE = ANISOTROPIC_BARYCENTRIC_MAP
SCALAR ANI_BM CONDITIONAL_STATS_BIN = 0 # Default value, if using conditional stats it allows to select the requested bin
SCALAR ANI_BM SOURCE_TENSOR = ANISOTROPIC_T 
SCALAR ANI_BM C_OFF = 0.0 # default value
SCALAR ANI_BM C_EXP = 1.0 # default value 
SCALAR ANI_BM UPDATE_ONLY_AT_DUMP = TRUE
SCALAR ANI_BM UPDATE_ONLY_AT_POSTPROC_DUMP = TRUE

SCALAR TI_value TYPE = POSTPROC
SCALAR TI_value POSTPROC_TYPE = EQUATION
SCALAR TI_value DATATYPE = REAL_NODE_SCALAR #SCALAR
SCALAR TI_value EQUATION_DEF =  "(((@U[1]-@U_MEAN[1])**2+(@U[2]-@U_MEAN[2])**2+(@U[3]-@U_MEAN[3])**2)**0.5)/8.0"

SCALAR TI_One_Thirds TYPE = POSTPROC
SCALAR TI_One_Thirds POSTPROC_TYPE = EQUATION
SCALAR TI_One_Thirds DATATYPE = REAL_NODE_SCALAR #SCALAR
SCALAR TI_One_Thirds EQUATION_DEF =  "(((1/3)*((@U[1]-@U_MEAN[1])**2+(@U[2]-@U_MEAN[2])**2+(@U[3]-@U_MEAN[3])**2))**0.5)/8.0"

SCALAR TKE_value TYPE = POSTPROC
SCALAR TKE_value POSTPROC_TYPE = EQUATION
SCALAR TKE_value DATATYPE = REAL_NODE_SCALAR
SCALAR TKE_value EQUATION_DEF =  "((@U[1]-@U_MEAN[1])**2+(@U[2]-@U_MEAN[2])**2+(@U[3]-@U_MEAN[3])**2)*(0.5)"

SCALAR VELOCITY_DEFICIT TYPE = CONSTANT
SCALAR VELOCITY_DEFICIT DATATYPE = REAL_NODE_SCALAR
SCALAR VELOCITY_DEFICIT DUMP = TRUE

SCALAR QC2 TYPE = POSTPROC
SCALAR QC2 POSTPROC_TYPE = QUALITY_CRITERION
SCALAR QC2 CRITERION = POPE

SCALAR KE TYPE = POSTPROC
SCALAR KE POSTPROC_TYPE = KINETIC_ENERGY

# Wind turbines inputs

# blade look-up table
LOOKUP_TABLE BLADE FORMAT = HDF
LOOKUP_TABLE BLADE FILE = 'blade_IEA15MW_FAST.h5'
LOOKUP_TABLE BLADE TYPE = GENERIC
LOOKUP_TABLE BLADE INTERPOLATION_TYPE = LINEAR


#-- ROTOR1 --
AL_VERTICAL_AXIS = 0.0 0.0 1.0
AL_INCIDENT_WIND = 1.0 0.0 0.0
AL_DIRECTORY = "ALM_output"

AL_COUPLING_LIB_DLL_FILE = "/Users/aparinam/PhD/NREL_Visit/Work/Coupling/Coupling_Library_Git/Coupling_Library/build/libY2_OpenFAST_Coupling_Library.so" 

# First wind turbine
ACTUATOR_SET ROTOR1 ACTUATOR_SET_TYPE = HAWT        # Horizontal Axis Wind Turbine
ACTUATOR_SET ROTOR1 NBLADE = 3                      # [3 (default) [-]]
ACTUATOR_SET ROTOR1 ROTOR_CENTER = 0.0 0.0 150.0
# ACTUATOR_SET ROTOR1 ROTOR_CENTER = 720.0 720.0 150.0
ACTUATOR_SET ROTOR1 HUB_RADIUS = 3.97
ACTUATOR_SET ROTOR1 BLADE_LENGTH = 116.03
ACTUATOR_SET ROTOR1 NDIM_PER_BLADE = 64            # [default is set according to the local cell size]
ACTUATOR_SET ROTOR1 ROTATION_SPEED = 0.600044196835            # [0.0 (default) [radian/s]]
ACTUATOR_SET ROTOR1 FORCE_TYPE = BEM_THEORY           # [BEM_THEORY (default) | IMPOSED]
ACTUATOR_SET ROTOR1 VELOCITY_CORRECTION = NONE # [NONE (default) | FILTERED_LL]
ACTUATOR_SET ROTOR1 FORCE_CORRECTION = NONE           # [NONE (default) | SHEN_2014 | SHEN_2005 | SANT | PRANDLT ]
ACTUATOR_SET ROTOR1 DYNAMIC_STALL = NONE              # [NONE (default) | BEAUDET (WIP) | BEDDOES-LEISHMAN (WIP)]
ACTUATOR_SET ROTOR1 LOOKUP_TABLE_NAME = BLADE
ACTUATOR_SET ROTOR1 POLARS_TYPE = FROM_LOOKUP_TABLE   # [FROM_LOOKUP_TABLE | FROM_USER | more on wiki] 
ACTUATOR_SET ROTOR1 CHORD_CASE = FROM_LOOKUP_TABLE
ACTUATOR_SET ROTOR1 TWIST_CASE = FROM_LOOKUP_TABLE
ACTUATOR_SET ROTOR1 DEFORMATION_TYPE = NONE           # [NONE (default) | STATIC | COUPLED ] 
ACTUATOR_SET ROTOR1 DEFORMATION_TYPE = COUPLED_OPENFAST   #        NONE    # [NONE (default) | STATIC | COUPLED ]
ACTUATOR_SET ROTOR1 OPENFAST_INPUTFILE = 'openfast_turbine_1/IEA-15-240-RWT-Monopile.fst'
ACTUATOR_SET ROTOR1 DEFORMATION_CASE = FROM_LOOKUP_TABLE # FROM_LOOKUP_TABLE
ACTUATOR_SET ROTOR1 YAW_ANGLE = 0.0                   # [0.0 (default) [°]]
ACTUATOR_SET ROTOR1 TILT_ANGLE = -6.0                  # [0.0 (default) [°]]
ACTUATOR_SET ROTOR1 PITCH_ANGLE = 0.0                 # [0.0 (default) [°]]
ACTUATOR_SET ROTOR1 CONE_ANGLE = -4                  # [0.0 (default) [°]]
ACTUATOR_SET ROTOR1 MOLLIFICATION_TYPE = CLASSIC     # [CLASSIC (default) | ALLM ]
ACTUATOR_SET ROTOR1 EPSILON_OVER_DELTAX = 3
#ACTUATOR_SET ROTOR1 EPSILON_C_OVER_C = 0.4           # [0.4 (default) [-] | if MOLLIFICATION_TYPE = ALLM] 
#ACTUATOR_SET ROTOR1 EPSILON_T_OVER_C = 0.2           # [0.2 (default) [-] | if MOLLIFICATION_TYPE = ALLM]
ACTUATOR_SET ROTOR1 MOLLIFICATION_NORMALIZED = FALSE  # [FALSE (default) | TRUE]
ACTUATOR_SET ROTOR1 GEARBOX_RATIO = 97.0              # Ratio between generator (1) and rotor (2) rotation speeds --> (1) / (2)
ACTUATOR_SET ROTOR1 DRIVETRAIN_INERTIA = 43702538.057 # Total drivetrain inertia around main rotation axis, including blades and hub inertia

# Stats
# ACTUATOR_SET ROTOR1 AZIMUTHAL_STATS = TRUE
ACTUATOR_SET ROTOR1 AZIMUTHAL_NBINS = 18
ACTUATOR_SET ROTOR1 RADIAL_STATS = FALSE
ACTUATOR_SET ROTOR1 DUMP_TYPE = HDF                       # [ NONE  | HDF (default) | ASCII (WIP)]

# Restart =================================
#RESTART_TYPE = GAMBIT
#RESTART_GAMBIT_MSH = 'meshes/al.msh'
