


SCALAR TI_value TYPE = POSTPROC
SCALAR TI_value POSTPROC_TYPE = EQUATION
SCALAR TI_value DATATYPE = REAL_NODE_SCALAR #SCALAR
SCALAR TI_value EQUATION_DEF =  "(((@U[1]-@U_MEAN[1])**2+(@U[2]-@U_MEAN[2])**2+(@U[3]-@U_MEAN[3])**2)**0.5)/8.0"


#SCALAR TI_Two_Thirds TYPE = POSTPROC
#SCALAR TI_Two_Thirds POSTPROC_TYPE = EQUATION
#SCALAR TI_Two_Thirds DATATYPE = REAL_NODE_SCALAR #SCALAR
#SCALAR TI_Two_Thirds EQUATION_DEF =  "(((2/3)*((@U[1]-@U_MEAN[1])**2+(@U[2]-@U_MEAN[2])**2+(@U[3]-@U_MEAN[3])**2))**0.5)/8.0"
#

SCALAR TI_One_Thirds TYPE = POSTPROC
SCALAR TI_One_Thirds POSTPROC_TYPE = EQUATION
SCALAR TI_One_Thirds DATATYPE = REAL_NODE_SCALAR #SCALAR
SCALAR TI_One_Thirds EQUATION_DEF =  "(((1/3)*((@U[1]-@U_MEAN[1])**2+(@U[2]-@U_MEAN[2])**2+(@U[3]-@U_MEAN[3])**2))**0.5)/8.0"


SCALAR TKE_value TYPE = POSTPROC
SCALAR TKE_value POSTPROC_TYPE = EQUATION
SCALAR TKE_value DATATYPE = REAL_NODE_SCALAR
SCALAR TKE_value EQUATION_DEF =  "((@U[1]-@U_MEAN[1])**2+(@U[2]-@U_MEAN[2])**2+(@U[3]-@U_MEAN[3])**2)*(0.5)"




SCALAR Q_CRITERION TYPE = POSTPROC
SCALAR Q_CRITERION POSTPROC_TYPE = Q_CRITERION
SCALAR Q_CRITERION UPDATE_ONLY_AT_DUMP = TRUE
SCALAR Q_CRITERION UPDATE_ONLY_AT_POSTPROC_DUMP = TRUE

SCALAR VORTICITY TYPE = POSTPROC
SCALAR VORTICITY POSTPROC_TYPE = VORTICITY
SCALAR VORTICITY SOURCE = U
SCALAR VORTICITY UPDATE_ONLY_AT_DUMP = TRUE
SCALAR VORTICITY UPDATE_ONLY_AT_POSTPROC_DUMP = TRUE

SCALAR VELOCITY_DEFICIT TYPE = CONSTANT
SCALAR VELOCITY_DEFICIT DATATYPE = REAL_NODE_SCALAR
SCALAR VELOCITY_DEFICIT DUMP = TRUE

SCALAR QC2 TYPE = POSTPROC
SCALAR QC2 POSTPROC_TYPE = QUALITY_CRITERION
SCALAR QC2 CRITERION = POPE
STATS U
STATS NU_T # Or NU_T with constant density solvers


SCALAR KE TYPE = POSTPROC
SCALAR KE POSTPROC_TYPE = KINETIC_ENERGY
#SCALAR KE VELOCITY_DATA_SOURCE = U      # default U



