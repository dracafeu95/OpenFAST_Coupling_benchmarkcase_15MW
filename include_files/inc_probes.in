

#==================================== Probes ==============================

# Point Probes ==============================
# Hub-height
PROBE pt1 TYPE = POINT
PROBE pt1 COORDINATES = 240 720 150
PROBE pt1 DUMP_DATA = U
PROBE pt1 DUMP_DATA = U_MEAN
PROBE pt1 DUMP_DATA = U_RMS
PROBE pt1 APPEND = TRUE
PROBE pt1 DUMP_NITER = 1
PROBE pt1 SOURCE_GRID = MAIN_GRID                # [MAIN_GRID (default)]
PROBE pt1 INTERPOLATION_TYPE = LINEAR            # [INVERSE_OF_DISTANCE (default)|LINEAR]
PROBE pt1 SEEDING_TYPE = CONFORMAL               # [NON_CONFORMAL (default)|CONFORMAL (to be used for flow rate evaluation)]

