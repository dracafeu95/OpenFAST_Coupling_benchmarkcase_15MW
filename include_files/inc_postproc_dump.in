# Dump Iso-Values  ====================================

POSTPROC_DUMP qcrit1 TYPE = HDF
POSTPROC_DUMP qcrit1 TOTAL_TIME_PERIOD = 1000
POSTPROC_DUMP qcrit1 NPART = 48
POSTPROC_DUMP qcrit1 PREFIX = 'postproc/qcrit1.sol'
POSTPROC_DUMP qcrit1 ELEMENT_FLAGGING = SCALAR_VALUE
POSTPROC_DUMP qcrit1 ELEMENT_FLAGGING_SCALAR = Q_CRITERION
POSTPROC_DUMP qcrit1 ELEMENT_FLAGGING_SCALAR_VALUE = 0.002

# ============================ Rotor Temporals  ====================================

TEMPORAL temporal TYPE = ASCII
TEMPORAL temporal FILE = "ROTOR1_temporals.txt"
TEMPORAL temporal APPEND = TRUE
TEMPORAL temporal DUMP_NBUFFER = 5
TEMPORAL temporal NITER_PERIOD = 1
#TEMPORAL temporal TIME_PERIOD = 1

TEMPORAL_DATA actuator_set_global TYPE = ACTUATOR_SET
TEMPORAL_DATA actuator_set_global DESTINATION = temporal
TEMPORAL_DATA actuator_set_global SOURCE = ROTOR1
TEMPORAL_DATA actuator_set_global LABEL = "R1_global"

